{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sunbird84/tden-skills/blob/master/schema/skill-v1.schema.json",
  "title": "TDEN Skill v1",
  "description": "JSON manifest for a TDEN scene-package recipe (a 'Skill') that RPs can fork into the toolkit Designer.",
  "type": "object",
  "required": ["id", "name", "version", "fields", "purpose", "lawful_basis", "auth_types", "max_validity_seconds"],
  "properties": {
    "id":              { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
    "name":            { "type": "string", "minLength": 1, "maxLength": 80 },
    "name_zh":         { "type": "string", "maxLength": 80 },
    "version":         { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description":     { "type": "string", "maxLength": 500 },
    "description_zh":  { "type": "string", "maxLength": 500 },
    "category": {
      "type": "string",
      "enum": ["kyc", "age-verification", "social", "ecommerce", "gov", "edu", "med", "fintech", "iot", "ai-agent", "other"]
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["tag", "required", "justification"],
        "properties": {
          "tag":           { "type": "string", "pattern": "^[a-z0-9_]{2,64}$" },
          "required":      { "type": "boolean" },
          "justification": { "type": "string", "minLength": 4, "maxLength": 200 },
          "justification_zh": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "purpose":          { "type": "string", "minLength": 10, "maxLength": 2000 },
    "purpose_zh":       { "type": "string", "maxLength": 2000 },
    "lawful_basis": {
      "type": "string",
      "enum": ["consent", "contract", "legal-obligation", "legitimate-interest", "vital-interest", "public-task"]
    },
    "auth_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["once", "short-term", "long-term", "permanent"] }
    },
    "max_validity_seconds": { "type": "integer", "minimum": 0, "maximum": 31536000 },
    "max_queries_per_day":  { "type": "integer", "minimum": 1, "maximum": 1000000 },
    "redirect_uri_template": { "type": "string", "description": "Suggested RP redirect URI pattern" },
    "compliance": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["gdpr", "ccpa", "fatf-travel-rule", "hipaa", "ferpa", "coppa", "pipl-china"]
      }
    },
    "author":          { "type": "string" },
    "author_url":      { "type": "string", "format": "uri" },
    "submitted_at":    { "type": "string", "format": "date" },
    "approved_at":     { "type": "string", "format": "date" },
    "license":         { "type": "string", "default": "CC0-1.0" }
  }
}
